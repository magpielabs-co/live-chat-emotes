{
  "name": "youtube-chat-emotes",
  "version": "1.0.0",
  "description": "Renders 7TV emotes in YouTube live chat.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:firefox": "npm run build && node scripts/build-firefox.mjs",
    "build:firefox-source": "node scripts/build-firefox-source.mjs",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.28",
    "@types/chrome": "^0.0.268",
    "archiver": "^7.0.1",
    "typescript": "^5.4.5",
    "vite": "^5.4.11",
    "vitest": "^1.6.0"
  }
}
